#include "FreeRTOS.h"
#include "main.h"


void process_command(command_t *pcmd)
{
	extract_command(pcmd);
	switch(curr_state)
	{

	case sMainMenu:
		xTaskNotify(handle_menu_task,0,eNoAction);
		break;
	case sLedEffect:
		xTaskNotify(handle_led_task,0,eNoAction);
		break;
	case sRtcMenu:
		xTaskNotify(handle_rtc_task,0,eNoAction);
		break;
	case sRtcTimeConfig:
		xTaskNotify(handle_rtc_task,0,eNoAction);
		break;
	case sRtcDateConfig:
		xTaskNotify(handle_rtc_task,0,eNoAction);
		break;
	case sRtcReport:
		xTaskNotify(handle_rtc_task,0,eNoAction);
		break;


	}


}

