	BaseType_t ret;
	command_t cmd;

	while(1)
	{

		/* Implement notify wait */

		ret =xTaskNotifyWait(0,0,NULL,portMAX_DELAY);
		if(ret == pdTRUE)
		{
			/* Process the user data(command) stored in input data queue*/
			process_command(&cmd);
		}


		/*Notify the command to relevant task */


	}
}

