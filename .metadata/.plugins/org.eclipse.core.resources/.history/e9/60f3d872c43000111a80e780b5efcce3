void led_task(void *param)
{
	uint32_t cmd_addr;
	command_t *cmd;
	const char* msg_led = "========================\n"
						  "|      LED Effect     |\n"
						  "========================\n"
						  "(none,e1,e2,e3,e4)\n"
						  "Enter your choice here : ";

	while(1){

		//this first notify wait is done so that task does not start executing , till its called for
		xTaskNotifyWait(0,0,&cmd_addr,portMAX_DELAY);

        xQueueSend(q_print_msg,&msg_led,portMAX_DELAY);

        xTaskNotifyWait(0,0,&cmd_addr,portMAX_DELAY);
        cmd = (command_t*)cmd_addr;

		if(cmd->len <= 4)
		{
			if(! strcmp((char*)cmd->payload,"none"))
				led_effect_stop();
			else if (! strcmp((char*)cmd->payload,"e1"))
				led_effect(1); // this function all , starts the timer
			else if (! strcmp((char*)cmd->payload,"e2"))
				led_effect(2);
			else if (! strcmp((char*)cmd->payload,"e3"))
				led_effect(3);
			else if (! strcmp((char*)cmd->payload,"e4"))
				led_effect(4);
			else
				xQueueSend(q_print_msg, &msg_inv, portMAX_DELAY);

		}
		else{
			xQueueSend(q_print_msg, &msg_inv, portMAX_DELAY);
		}
		curr_state = sMainMenu;
		xTaskNotify(handle_menu_task,0,eNoAction);

	}
}


uint32_t  extract_command(command_t *pcmd)
{
	uint8_t item;
	BaseType_t status;

	status =uxQueueMessagesWaiting(q_user_data);
	if(!status) return -1;
	uint8_t i =0;

	do {
		status = xQueueReceive(q_user_data,&item,0);
		if(status == pdTRUE)
		{
			pcmd->payload[i++]=item;

		}

	}while(item !='\r');

	pcmd->payload[i-1]='\0';
	pcmd->len=i-1;

	return 0;

}

void process_command(command_t *pcmd)
{
	extract_command(pcmd);
	switch(curr_state)
	{

	case sMainMenu:
		xTaskNotify(handle_menu_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sLedEffect:
		xTaskNotify(handle_led_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sRtcMenu:
		xTaskNotify(handle_rtc_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sRtcTimeConfig:
		xTaskNotify(handle_rtc_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sRtcDateConfig:
		xTaskNotify(handle_rtc_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sRtcReport:
		xTaskNotify(handle_rtc_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;


	}


}

