		xQueueReceive(q_print_msg,&msg, portMAX_DELAY); // waits for infinity if the data is not available in the queue;
		HAL_UART_Transmit(&huart2,(uint8_t*)msg,strlen((char *)msg),HAL_MAX_DELAY);

	}

}
