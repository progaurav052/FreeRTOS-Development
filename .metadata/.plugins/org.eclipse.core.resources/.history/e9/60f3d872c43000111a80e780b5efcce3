const char *msg_inv = "////Invalid option////\n";

void menu_task(void *param){
	//print the main task selection menu first
	uint32_t cmd_addr;
    command_t *cmd;
    int option;
	const char *taskSelectionMenu = "\n========================\n"
									  "|         Menu         |\n"
									  "========================\n"
										"LED effect    ----> 0\n"
										"Date and time ----> 1\n"
										"Exit          ----> 2\n"
										"Enter your choice here : ";

	while(1)
	{
		xQueueSend(q_print_msg,&taskSelectionMenu,portMAX_DELAY);

		xTaskNotifyWait(0,0,&cmd_addr,portMAX_DELAY); // infinite waiting , cmd_handle task will notify , than this task will resume here
		cmd = (command_t*)cmd_addr; // notification value i.e the command entered (0,1,2 from main menu task selection will be stored in command its pointer is stored in cmd_addr)
		if(cmd->len == 1)
		{
			option = cmd->payload[0] - 48;
			switch (option) {
			case 0:
				curr_state = sLedEffect;
				xTaskNotify(handle_led_task, 0, eNoAction);
				break;
			case 1:
				curr_state = sRtcMenu;
				xTaskNotify(handle_rtc_task, 0, eNoAction);
				break;
			case 2: /*implement exit */
				break;
			default:
				xQueueSend(q_print_msg, &msg_inv, portMAX_DELAY);
				continue;
			}

		} else {
			//invalid entry
			xQueueSend(q_print_msg, &msg_inv, portMAX_DELAY);
			continue;
		}


		//wait till main menu is notified again

		xTaskNotifyWait(0,0,NULL,portMAX_DELAY);

		//other task after completing its run for one time will notify the menu task


	}

}
