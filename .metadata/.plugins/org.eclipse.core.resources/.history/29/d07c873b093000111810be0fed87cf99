void extract_command(command_t *pcmd)
{
	uint8_t item;
	BaseType_t status;

	status =uxQueueMessagesWaiting(q_user_data);
	if(!status) return -1;
	uint8_t i =0;

	do {
		status = xQueueReceive(q_user_data,&item,0);
		if(status == pdTRUE)
		{
			pcmd->payload[i++]=item;

		}

	}while(item !='\n');
	pcmd->payload[i-1]='\0';
	pcmd->len=i-1;

	return;


}

void process_command(command_t *pcmd)
{
	extract_command(pcmd);
	switch(curr_state)
	{

	case sMainMenu:
		xTaskNotify(handle_menu_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sLedEffect:
		xTaskNotify(handle_led_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sRtcMenu:
		xTaskNotify(handle_rtc_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sRtcTimeConfig:
		xTaskNotify(handle_rtc_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sRtcDateConfig:
		xTaskNotify(handle_rtc_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;
	case sRtcReport:
		xTaskNotify(handle_rtc_task,(uint32_t)pcmd,eSetValueWithOverwrite);
		break;


	}


}

